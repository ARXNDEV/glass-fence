#!/bin/bash
cd "$(dirname "$0")"
cd ../../utils/xorg-deps/xf86-input-glass-fence

#
# aborting if any command returns a non-zero value
set -e

#
# check if docker image exists
if [ -z "$(docker images -q xf86-input-glass-fence)" ]; then
    echo "Docker image not found, building it"
    docker build -t xf86-input-glass-fence .
fi

#
# if there is no ./configure script, run autogen.sh and configure
if [ ! -f ./configure ]; then
    docker run -v $PWD/:/app --rm xf86-input-glass-fence bash -c './autogen.sh && ./configure'
fi

#
# make install
docker run -v $PWD/:/app --rm xf86-input-glass-fence bash -c 'make && make install DESTDIR=/app/build'

#
# replace input driver in container
docker cp "${PWD}/build/usr/local/lib/xorg/modules/input/glass-fence_drv.so" glass-fence_server_dev:/usr/lib/xorg/modules/input/glass-fence_drv.so

#
# restart server
docker exec glass-fence_server_dev supervisorctl -c /etc/glass-fence/supervisord.conf restart x-server
