#!/bin/bash
cd "$(dirname "$0")"

if [ "$(docker images -q glass-fence_server:src 2> /dev/null)" == "" ]; then
    echo "Image 'glass-fence_server:src' not found. Run ./build first."
    exit 1
fi

#
# build server
docker run --rm -it \
    -v "${PWD}/../:/src" \
    --entrypoint="/bin/bash" \
    glass-fence_server:src -c '[ -f ./bin/golangci-lint ] || curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/master/install.sh | sh -s v1.31.0;./bin/golangci-lint run';
