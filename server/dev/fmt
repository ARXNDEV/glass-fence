#!/bin/bash
cd "$(dirname "$0")"

if [ "$(docker images -q glass-fence_server:src 2> /dev/null)" == "" ]; then
    echo "Image 'glass-fence_server:src' not found. Run ./build first."
    exit 1
fi

docker run -it --rm \
    --entrypoint="go" \
    -v "${PWD}/../:/src" \
    glass-fence_server:src fmt ./...
